ARG tag_ref_name
ARG REQUIREMENTS_FILE=dev_requirements.txt
ARG RUNTIME_BASE_IMAGE=base-py-sdk-hardened
ARG EXTRA_BUILDER_LIBS=""

FROM nvidia/cuda:12.8.0-runtime-ubuntu22.04 AS cuda

FROM python:3.8.10-slim-buster AS requirements-builder

ENV LANG=C.UTF-8 \
  PYTHONDONTWRITEBYTECODE=1 \
  PYTHONUNBUFFERED=1 \
  PIP_DISABLE_PIP_VERSION_CHECK=1 \
  PIP_NO_CACHE_DIR=1 \
  PIP_PREFER_BINARY=1

ARG REQUIREMENTS_FILE
ARG EXTRA_BUILDER_LIBS
RUN set -eux; \
  sed -i \
    -e 's|deb.debian.org/debian|archive.debian.org/debian|g' \
    -e 's|security.debian.org/debian-security|archive.debian.org/debian-security|g' \
    -e '/buster-updates/d' \
    /etc/apt/sources.list; \
  printf 'Acquire::Check-Valid-Until "false";\n' > /etc/apt/apt.conf.d/99no-check-valid-until; \
  apt-get update; \
  apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    cmake \
    git \
    libgeos-dev \
    ninja-build \
    pkg-config \
    ${EXTRA_BUILDER_LIBS}; \
  rm -rf /var/lib/apt/lists/*

COPY ${REQUIREMENTS_FILE} /tmp/requirements.txt

RUN set -eux; \
  python -m venv /opt/venv; \
  /opt/venv/bin/python -m ensurepip --upgrade; \
  /opt/venv/bin/python -m pip install --no-cache-dir --upgrade pip wheel; \
  /opt/venv/bin/python -m pip install --no-cache-dir setuptools==69.5.1; \
  /opt/venv/bin/python -m pip install --no-cache-dir requests; \
  /opt/venv/bin/python -m pip install --no-cache-dir numpy; \
  /opt/venv/bin/python -m pip install --no-cache-dir torch==1.10.2 torchvision==0.11.3; \
  if [ -s /tmp/requirements.txt ]; then \
    MMCV_WITH_OPS=1 /opt/venv/bin/python -m pip wheel --no-cache-dir --no-build-isolation -r /tmp/requirements.txt -w /tmp/wheels; \
  else \
    mkdir -p /tmp/wheels; \
  fi

FROM --platform=linux/amd64 python:3.8.10-slim-buster AS runtime

ENV LANG=C.UTF-8 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

ARG REQUIREMENTS_FILE

COPY ${REQUIREMENTS_FILE} /tmp/requirements.txt

RUN --mount=from=requirements-builder,source=/tmp/wheels,target=/tmp/wheels,ro \
  set -eux; \
  ln -sf /usr/local/bin/python3 /usr/local/bin/python; \
  ln -sf /usr/local/bin/python3 /usr/bin/python; \
  sed -i \
    -e 's|deb.debian.org/debian|archive.debian.org/debian|g' \
    -e 's|security.debian.org/debian-security|archive.debian.org/debian-security|g' \
    -e '/buster-updates/d' \
    /etc/apt/sources.list; \
  printf 'Acquire::Check-Valid-Until "false";\n' > /etc/apt/apt.conf.d/99no-check-valid-until; \
  apt-get update; \
  apt-get install -y --no-install-recommends \
    libglib2.0-0 \
    libgl1 \
    libmagic1 \
    libsm6 \
    libxrender1 \
    libxext6 \
    libxcb1 \
    libx11-6 \
    libgeos-c1v5 \
    ffmpeg; \
  python -m venv /opt/venv; \
  if [ -s /tmp/requirements.txt ]; then \
    /opt/venv/bin/python -m ensurepip --upgrade; \
    set -- /tmp/wheels/*.whl; \
    if [ -e "$1" ]; then \
      /opt/venv/bin/python -m pip install --no-cache-dir --no-compile --no-index /tmp/wheels/*.whl; \
      rm -rf \
        /opt/venv/lib/python*/site-packages/pip* \
        /opt/venv/lib/python*/site-packages/setuptools* \
        /opt/venv/lib/python*/site-packages/wheel* \
        /opt/venv/lib/python*/site-packages/pkg_resources* \
        /opt/venv/lib/python*/site-packages/_distutils_hack* \
        /opt/venv/lib/python*/site-packages/_distutils* \
        /opt/venv/lib/python*/site-packages/distutils-precedence.pth \
        /opt/venv/bin/pip \
        /opt/venv/bin/pip3 \
        /opt/venv/bin/pip3.* \
        /opt/venv/bin/easy_install \
        /opt/venv/bin/easy_install-* \
        /opt/venv/bin/wheel; \
    fi; \
  fi; \
  rm -rf \
    /var/lib/apt/lists/* \
    /usr/bin/apt \
    /usr/bin/apt-get \
    /usr/bin/apt-cache \
    /usr/bin/apt-mark \
    /usr/bin/apt-key \
    /usr/bin/dpkg \
    /usr/bin/dpkg-deb \
    /usr/bin/dpkg-query \
    /usr/bin/dpkg-divert \
    /usr/bin/git \
    /usr/bin/curl \
    /usr/bin/wget \
    /usr/local/lib/python3.8/site-packages/pip* \
    /usr/local/lib/python3.8/site-packages/setuptools* \
    /usr/local/lib/python3.8/site-packages/wheel* \
    /usr/local/lib/python3.8/site-packages/pkg_resources* \
    /usr/local/lib/python3.8/site-packages/_distutils* \
    /usr/local/lib/python3.8/site-packages/distutils-precedence.pth; \
  find /opt/venv -type d -name '__pycache__' -prune -exec rm -rf {} +; \
  find /opt/venv -type f \( -name '*.pyc' -o -name '*.pyo' \) -delete; \
  find /opt/venv/lib/python*/site-packages -type d \( -name 'tests' -o -name 'test' \) -prune -exec rm -rf {} +; \
  rm -rf /tmp/requirements.txt

ENV PATH="/opt/venv/bin:$PATH"

COPY --from=cuda /usr/local/cuda-12.8/targets/x86_64-linux/lib/libcudart.so* /usr/lib/
COPY --from=cuda /usr/local/cuda-12.8/targets/x86_64-linux/lib/libcublas.so* /usr/lib/
COPY --from=cuda /usr/local/cuda-12.8/targets/x86_64-linux/lib/libcublasLt.so* /usr/lib/
COPY --from=cuda /usr/local/cuda-12.8/targets/x86_64-linux/lib/libcufft.so* /usr/lib/
COPY --from=cuda /usr/local/cuda-12.8/targets/x86_64-linux/lib/libcurand.so* /usr/lib/
COPY --from=cuda /usr/local/cuda-12.8/targets/x86_64-linux/lib/libcusolver.so* /usr/lib/
COPY --from=cuda /usr/local/cuda-12.8/targets/x86_64-linux/lib/libcusparse.so* /usr/lib/
COPY --from=cuda /usr/local/cuda-12.8/targets/x86_64-linux/lib/libnvrtc.so* /usr/lib/
COPY --from=cuda /usr/local/cuda-12.8/targets/x86_64-linux/lib/libnvJitLink.so* /usr/lib/

ENV LD_LIBRARY_PATH="/usr/lib:/usr/local/lib" \
	NVIDIA_VISIBLE_DEVICES=all \
	NVIDIA_DRIVER_CAPABILITIES=compute,utility
